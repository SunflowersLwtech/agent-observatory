# Auth0
AUTH0_SECRET=
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# OpenAI
OPENAI_API_KEY=

# Auth0 Token Vault (auto-configured via Auth0 dashboard)
# These are set in the Auth0 dashboard social connections
# Google: google-oauth2
# GitHub: github
# Slack: slack

# Upstash Redis — persistent event store (install via Vercel Marketplace)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Anomaly detection thresholds (optional, sensible defaults built in)
# ANOMALY_VELOCITY=15
# ANOMALY_ERROR_BURST=3
# ANOMALY_CROSS_SERVICE_WINDOW=10000
